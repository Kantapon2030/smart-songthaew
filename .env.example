# ──────────────────────────────────────────────────────────────────────────────
#  .env.example — Smart Songthaew Tracker
#  คัดลอกไฟล์นี้เป็น .env แล้วใส่ค่าจริง (อย่า commit .env เข้า git!)
# ──────────────────────────────────────────────────────────────────────────────

# ── Google Maps ───────────────────────────────────────────────────────────────
# เปิดใช้: Maps JavaScript API, Directions API, Distance Matrix API
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# ── Firebase Realtime Database ────────────────────────────────────────────────
# URL ของ Firebase Realtime Database (ไม่ต้องใส่ถ้า default ตรงกับ project)
FIREBASE_DATABASE_URL=https://YOUR_PROJECT_ID-default-rtdb.asia-southeast1.firebasedatabase.app

# ── Firebase Service Account (สำหรับ Production / Vercel) ────────────────────
# วิธีได้ค่า: Firebase Console → Project Settings → Service Accounts → Generate new private key
# แปลง JSON → Single Line: ใน PowerShell: (Get-Content firebase-service-account.json -Raw) -replace "`r`n","" | Set-Clipboard
# แปลง JSON → Single Line: ใน Terminal:   cat firebase-service-account.json | tr -d '\n' | pbcopy
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"YOUR_PROJECT_ID",...paste_full_json_here...}

# ── JWT Auth ──────────────────────────────────────────────────────────────────
# สร้าง secret แบบสุ่ม: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_random_jwt_secret_here_minimum_32_chars
